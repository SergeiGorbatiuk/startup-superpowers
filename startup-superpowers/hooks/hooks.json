{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-core-md.mjs\"",
            "timeout": 15,
            "statusMessage": "Checking startup/core.md conventions..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-competitors-md.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking competitor file conventions..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-hypotheses-md.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking hypothesis file conventions..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-interview-scripts-md.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking interview script conventions..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-interview-md.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking interview analysis conventions..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-surveys-md.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking survey conventions..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-mvp-plan-md.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking MVP plan conventions..."
          }
        ]
      }
    ]
  }
}
